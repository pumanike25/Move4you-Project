<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/text_system_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
            android:background="@drawable/bg_system_message"
        android:backgroundTint="#FFF3C4" android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="🔒 Messages to this chat and calls are now secured with end-to-end encryption."
        android:textAlignment="center"
        android:textColor="#5A4A1E"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>