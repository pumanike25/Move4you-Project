<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:gravity="center"
            android:background="@color/white">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:contentDescription="Profile image"
                android:background="@drawable/circle_background"
                android:padding="4dp"
                android:elevation="4dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="22sp"
                android:textColor="@color/black"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:tabIndicatorColor="@color/primary"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextColor="@android:color/darker_gray"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem android:text="Personal Data"  android:layout_height="1dp" android:layout_width="1dp"/>
        <com.google.android.material.tabs.TabItem android:text="Activity"  android:layout_height="1dp" android:layout_width="1dp"/>
        <com.google.android.material.tabs.TabItem android:text="Public Profile"  android:layout_height="1dp" android:layout_width="1dp"/>
    </com.google.android.material.tabs.TabLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/userDataView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Personal Details"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:id="@+id/tvHeight" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#424242" android:layout_marginBottom="12dp" android:text="Height: Not set" app:drawableStartCompat="@drawable/ic_person" android:drawablePadding="12dp"/>
                        <TextView android:id="@+id/tvWeight" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#424242" android:layout_marginBottom="12dp" android:text="Weight: Not set" app:drawableStartCompat="@drawable/ic_person" android:drawablePadding="12dp"/>
                        <TextView android:id="@+id/tvAge" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#424242" android:layout_marginBottom="12dp" android:text="Age: Not set" app:drawableStartCompat="@drawable/ic_history" android:drawablePadding="12dp"/>
                        <TextView android:id="@+id/tvGender" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#424242" android:layout_marginBottom="12dp" android:text="Gender: Not set" app:drawableStartCompat="@drawable/ic_person" android:drawablePadding="12dp"/>
                        <TextView android:id="@+id/tvMoneyGoal" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="#424242" android:layout_marginBottom="24dp" android:text="Monthly Goal: Not set" app:drawableStartCompat="@android:drawable/ic_menu_myplaces" android:drawablePadding="12dp"/>

                        <Button
                            android:id="@+id/btnEditBiometrics"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Edit Biometrics"
                            android:backgroundTint="@color/primary"
                            android:textColor="@color/white"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/walkingStatsView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_person" app:tint="@color/primary" android:layout_marginBottom="8dp"/>

                        <TextView android:id="@+id/tvTotalSteps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/black" android:text="0 Steps" android:layout_marginBottom="16dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:baselineAligned="false">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Distance" android:textSize="14sp" android:textColor="@android:color/darker_gray"/>
                                <TextView android:id="@+id/tvDistanceWalked" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp" android:textColor="@color/black" android:textStyle="bold" android:text="0.0 km"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calories" android:textSize="14sp" android:textColor="@android:color/darker_gray"/>
                                <TextView android:id="@+id/tvCaloriesBurned" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp" android:textColor="@color/black" android:textStyle="bold" android:text="0 kcal"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView android:id="@+id/tvHealthBenefits" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#4CAF50" android:textStyle="italic" android:textAlignment="center" android:layout_marginTop="20dp" android:text="Keep moving!"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/publicProfileView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy Settings"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginBottom="16dp"/>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPrivacy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Private Profile (Hide Trophies)"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:layout_marginBottom="24dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose Trophies to Display (Max 3):"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:id="@+id/trophiesCheckboxContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="24dp">
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnSavePublicSettings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Save Public Profile"
                            android:backgroundTint="@color/primary"
                            android:textColor="@color/white"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </FrameLayout>
    </ScrollView>
</LinearLayout>