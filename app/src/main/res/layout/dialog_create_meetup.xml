<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/MeetupInputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Plan a Meetup"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/etMeetupName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Meetup Name (e.g. Coffee, Movie)"
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etMeetupDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Description (Optional)"
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:id="@+id/btnPickDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_month" app:tint="@color/primary"/>
                        <TextView android:id="@+id/tvSelectedDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Date" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnPickTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="@color/primary"/>
                        <TextView android:id="@+id/tvSelectedTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Time" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <EditText
                    android:id="@+id/etMeetupAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Type address OR pick on map below"
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap on the map to set location:"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.gms.maps.MapView
                    android:id="@+id/mapViewMeetup"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />

                <ImageView
                    android:id="@+id/btnToggleFullscreen"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:background="#DDFFFFFF"
                    android:src="@android:drawable/ic_menu_zoom"
                    app:tint="@color/primary"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <Button
                android:id="@+id/btnSendMeetup"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Send Invitation"
                android:textSize="16sp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>